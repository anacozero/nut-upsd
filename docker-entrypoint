#!/bin/sh
# Generate NUT configuration from environment, then hand off to the daemons.
# NB: no `set -x` here — it would echo the generated passwords into the logs.
set -eu

# Resolve a password: prefer the contents of a *_FILE path (Docker/K8s secrets),
# then the plain value, otherwise generate a random one.
#   $1 = current value   $2 = path from <VAR>_FILE (may be empty)
load_secret() {
	_val="$1"
	_file="$2"
	if [ -n "$_file" ]; then
		if [ ! -r "$_file" ]; then
			echo "ERROR: secret file '$_file' is not readable" >&2
			exit 1
		fi
		_val="$(cat "$_file")"
	fi
	if [ -z "$_val" ]; then
		_val="$(dd if=/dev/urandom bs=18 count=1 2>/dev/null | base64)"
	fi
	printf '%s' "$_val"
}

API_PASSWORD="$(load_secret "${API_PASSWORD:-}" "${API_PASSWORD_FILE:-}")"
ADMIN_PASSWORD="$(load_secret "${ADMIN_PASSWORD:-}" "${ADMIN_PASSWORD_FILE:-}")"

cat >/etc/nut/ups.conf <<EOF
[$UPS_NAME]
	desc = "$UPS_DESC"
	driver = $UPS_DRIVER
	port = $UPS_PORT
EOF

cat >/etc/nut/upsd.conf <<EOF
LISTEN 0.0.0.0 3493
EOF

cat >/etc/nut/upsd.users <<EOF
[admin]
	password = $ADMIN_PASSWORD
	actions = set
	actions = fsd
	instcmds = all
[monitor]
	password = $API_PASSWORD
	upsmon master
EOF

cat >/etc/nut/upsmon.conf <<EOF
MONITOR $UPS_NAME@localhost 1 monitor $API_PASSWORD master
SHUTDOWNCMD "$SHUTDOWN_CMD"
EOF

# Restrict the generated config (contains passwords) to root and the nut group.
chown -R root:nut /etc/nut
chmod 640 /etc/nut/ups.conf /etc/nut/upsd.conf /etc/nut/upsd.users /etc/nut/upsmon.conf

# The USB driver runs as the unprivileged nut user and needs access to the device.
if [ -d /dev/bus/usb ]; then
	chgrp -R nut /dev/bus/usb
else
	echo "WARNING: /dev/bus/usb not present — pass '--device /dev/bus/usb/...' (or mount it)" >&2
fi

upsdrvctl start
upsd
exec upsmon -D
